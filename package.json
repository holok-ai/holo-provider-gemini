{
  "name": "@holokai/holo-provider-gemini",
  "version": "1.2.2",
  "type": "module",
  "description": "Google Gemini provider plugin for Holo LLM Gateway",
  "author": "Holokai",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holokai/holo-provider-gemini.git"
  },
  "bugs": {
    "url": "https://github.com/holokai/holo-provider-gemini/issues"
  },
  "homepage": "https://github.com/holokai/holo-provider-gemini#readme",
  "keywords": [
    "holokai",
    "holo",
    "plugin",
    "provider",
    "gemini",
    "google",
    "ai",
    "llm"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@holokai/sdk": "^1.1.0"
  },
  "dependencies": {
    "@google/genai": "^0.11.0"
  },
  "devDependencies": {
    "@holokai/provider-contract-tests": "*",
    "@types/node": "^24.0.11",
    "typescript": "^5.8.3"
  }
}
