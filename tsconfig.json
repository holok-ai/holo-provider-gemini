      ],
      "@holokai/holo-sdk/core": [
        "../../packages/holo-sdk/src/core/index.ts"
      ],
      "@holokai/holo-sdk/plugin": [
        "../../packages/holo-sdk/src/plugin/index.ts"
      ],
      "@holokai/holo-sdk/provider": [
        "../../packages/holo-sdk/src/provider/index.ts"
      ],
      "@holokai/holo-sdk/holo": [
        "../../packages/holo-sdk/src/holo/index.ts"
      ],
      "@holokai/holo-sdk/notification": [
