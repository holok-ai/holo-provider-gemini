{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": [
      "ESNext",
      "ESNext.Intl"
    ],
    "baseUrl": ".",
    "paths": {
      "@holokai/types": [
        "../../packages/types/src/index.ts"
      ],
      "@holokai/sdk": [
        "../../packages/sdk/src/index.ts"
      ],
      "@holokai/sdk/provider": [
        "../../packages/sdk/src/provider/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "tests/**/*"
  ],
  "references": [
    {
      "path": "../../packages/types"
    },
    {
      "path": "../../packages/sdk"
    }
  ]
}
