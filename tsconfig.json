{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": [
      "ESNext",
      "ESNext.Intl"
    ],
    "baseUrl": ".",
    "paths": {
      "@holokai/types": ["../../packages/types/src/index.ts"],
      "@holokai/types/holo": ["../../packages/types/src/holo/index.ts"],
      "@holokai/types/entities": ["../../packages/types/src/entities/index.ts"],
      "@holokai/types/config": ["../../packages/types/src/config/index.ts"],
      "@holokai/types/worker": ["../../packages/types/src/worker/index.ts"],
      "@holokai/types/notification": ["../../packages/types/src/notification/index.ts"],
      "@holokai/types/routing": ["../../packages/types/src/routing/index.ts"],
      "@holokai/types/api": ["../../packages/types/src/api/index.ts"],
      "@holokai/types/provider": ["../../packages/types/src/provider/index.ts"],
      "@holokai/types/logger": ["../../packages/types/src/logger/index.ts"],
      "@holokai/types/plugin": ["../../packages/types/src/plugin/index.ts"],
      "@holokai/sdk": ["../../packages/sdk/src/index.ts"],
      "@holokai/sdk/core": ["../../packages/sdk/src/core/index.ts"],
      "@holokai/sdk/plugin": ["../../packages/sdk/src/plugin/index.ts"],
      "@holokai/sdk/provider": ["../../packages/sdk/src/provider/index.ts"],
      "@holokai/sdk/holo": ["../../packages/sdk/src/holo/index.ts"],
      "@holokai/sdk/notification": ["../../packages/sdk/src/notification/index.ts"],
      "@holokai/sdk/client": ["../../packages/sdk/src/client/index.ts"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "tests/**/*"
  ],
  "references": [
    {
      "path": "../../packages/types"
    },
    {
      "path": "../../packages/sdk"
    }
  ]
}
