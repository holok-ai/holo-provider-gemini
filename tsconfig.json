        "../../packages/holo-types/src/entities/index.ts"
      ],
      "@holokai/holo-types/config": [
        "../../packages/holo-types/src/config/index.ts"
      ],
      "@holokai/holo-types/worker": [
        "../../packages/holo-types/src/worker/index.ts"
      ],
      "@holokai/holo-types/notification": [
        "../../packages/holo-types/src/notification/index.ts"
      ],
      "@holokai/holo-types/routing": [
        "../../packages/holo-types/src/routing/index.ts"
      ],
      "@holokai/holo-types/api": [
        "../../packages/holo-types/src/api/index.ts"
      ],
